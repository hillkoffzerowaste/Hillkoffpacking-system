# Shared backend URL visible to marketplace OAuth callbacks and webhooks.
# Production must use HTTPS.
PUBLIC_API_URL=https://api.example.com/api

# Encrypts access/refresh tokens stored in marketplace_connections.
# Generate a long random value and never commit the real key.
INTEGRATION_TOKEN_ENCRYPTION_KEY=replace-with-at-least-32-random-characters

# Shopee Open Platform
SHOPEE_PARTNER_ID=
SHOPEE_PARTNER_KEY=
SHOPEE_API_BASE_URL=https://partner.shopeemobile.com
SHOPEE_CALLBACK_URL=https://api.example.com/api/integrations/shopee/callback
SHOPEE_WEBHOOK_SECRET=
SHOPEE_AUTH_PATH=/api/v2/shop/auth_partner
SHOPEE_TOKEN_PATH=/api/v2/auth/token/get
SHOPEE_REFRESH_PATH=/api/v2/auth/access_token/get
SHOPEE_ORDER_LIST_PATH=/api/v2/order/get_order_list
SHOPEE_ORDER_DETAIL_PATH=/api/v2/order/get_order_detail

# Lazada Open Platform — Thailand endpoints by default.
LAZADA_APP_KEY=
LAZADA_APP_SECRET=
LAZADA_API_BASE_URL=https://api.lazada.co.th/rest
LAZADA_AUTH_BASE_URL=https://auth.lazada.com/rest
LAZADA_AUTHORIZE_URL=https://auth.lazada.com/oauth/authorize
LAZADA_CALLBACK_URL=https://api.example.com/api/integrations/lazada/callback
LAZADA_WEBHOOK_SECRET=
LAZADA_TOKEN_PATH=/auth/token/create
LAZADA_REFRESH_PATH=/auth/token/refresh
LAZADA_ORDERS_PATH=/orders/get
LAZADA_ORDER_ITEMS_PATH=/order/items/get

# TikTok Shop Partner Center
TIKTOK_SHOP_APP_KEY=
TIKTOK_SHOP_APP_SECRET=
TIKTOK_SHOP_SERVICE_ID=
TIKTOK_SHOP_API_BASE_URL=https://open-api.tiktokglobalshop.com
TIKTOK_SHOP_AUTHORIZE_URL=https://services.tiktokshop.com/open/authorize
TIKTOK_SHOP_CALLBACK_URL=https://api.example.com/api/integrations/tiktok/callback
TIKTOK_SHOP_WEBHOOK_SECRET=
TIKTOK_SHOP_TOKEN_PATH=/api/v2/token/get
TIKTOK_SHOP_REFRESH_PATH=/api/v2/token/refresh
TIKTOK_SHOP_ORDERS_PATH=/order/202309/orders/search
TIKTOK_SHOP_ORDER_DETAIL_PATH=/order/202309/orders
