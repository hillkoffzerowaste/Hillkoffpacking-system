# Vercel frontend build
VITE_DATA_MODE=local
VITE_BASE_PATH=/

# Optional Express API base for local/staged backend
VITE_API_BASE=http://localhost:4000/api

# Firebase config for future production data layer
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# Optional app login gate. For Firebase mode, password is stored in Firebase Auth, not in this file.
VITE_LOGIN_USERNAME=packing
VITE_LOGIN_EMAIL=

