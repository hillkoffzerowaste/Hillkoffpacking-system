rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    function signedIn() {
      return request.auth != null;
    }

    function operator() {
      return signedIn();
    }

    match /orders/{orderId} {
      allow read, write: if operator();
    }

    match /scan_events/{eventId} {
      allow read, write: if operator();
    }

    match /sales_dispatch_scans/{scanId} {
      allow read, write: if operator();
    }

    match /packers/{packerId} {
      allow read, write: if operator();
    }

    match /shipping_providers/{providerId} {
      allow read, write: if operator();
    }

    match /import_batches/{batchId} {
      allow read, write: if operator();
    }

    match /product_barcodes/{barcodeId} {
      allow read, write: if operator();
    }
  }
}
